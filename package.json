{
  "name": "reconnect",
  "displayName": "Reconnect",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --appIdSuffix 'debug' --mode=localDebug",
    "android:release:preprod": "react-native run-android --appIdSuffix 'preprod' --mode=preprodRelease ",
    "android:release": "react-native run-android --appIdSuffix 'prod' --mode=prodRelease ",
    "run:ios": "npx expo run:ios",
    "run:android": "npx expo run:android --variant=developmentDebug",
    "preprod:ios": "npx eas build --platform ios --profile preprod",
    "preprod:android": "npx eas build --platform android --profile preprod",
    "prod:ios": "npx eas build --platform ios --profile prod",
    "prod:android": "npx eas build --platform android --profile prod",
    "ios": "react-native run-ios",
    "start": "npx expo start --dev-client",
    "test": "npm run test:types && jest",
    "jest": "jest",
    "test:coverage": "jest --coverage",
    "ts": "tsc -p ./",
    "ts:check": "tsc -p ./",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "test:types": "tsc --noEmit --resolveJsonModule",
    "pod:install": "(cd ios && bundle exec pod install)"
  },
